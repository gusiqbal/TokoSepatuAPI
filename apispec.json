{
  "openapi": "3.1.0",
  "info": {
    "title": "Category Restful Api",
    "description": "Api Spec for Category Rest Api",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:3000/api"
    }
  ],
  "paths": {
    "/categories" : {
      "get" : {
        "description": "List all categorioes",
        "responses": {
          "200": {
            "description": " Success get All Categories",
            "content": {
              "application/json" : {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code" : {
                      "type": "number"
                    },
                    "status" : {
                      "type": "string"
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
